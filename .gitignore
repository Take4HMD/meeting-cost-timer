# Python cache / test artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Build / distribution artifacts
build/*
!build/.gitkeep
dist/*
!dist/.gitkeep
installer/*
!installer/.gitkeep

# Runtime logs
logs/*
!logs/.gitkeep
*.log

# Local application settings / generated data
config/app_settings.json
config/app_settings_broken_*.json
data/*
!data/.gitkeep

# Editor / OS files
.vscode/
.idea/
*.code-workspace
Thumbs.db
Desktop.ini
